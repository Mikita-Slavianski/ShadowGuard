@{
    ViewData["Title"] = "Исправление паролей";
}

<div class="container mt-5">
    <div class="alert alert-success">
        <h4>@ViewBag.Message</h4>
        <p><strong>Пользователей обновлено:</strong> @ViewBag.Users</p>
        <p><strong>Тест верификации:</strong> @ViewBag.VerifyTest</p>
        <hr>
        <p><strong>Новый хеш:</strong></p>
        <code class="d-block p-2 bg-light">@ViewBag.Hash</code>
        <hr>
        <p><strong>Теперь все пользователи могут войти с паролем:</strong> <code>password123</code></p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary mt-3">Перейти ко входу</a>
    </div>
</div>