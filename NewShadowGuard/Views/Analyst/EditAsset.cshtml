@model NewShadowGuard.Models.Asset
@{
    ViewData["Title"] = "Редактировать актив";
}

<h2>✏️ Редактировать актив</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <h5>Ошибки валидации:</h5>
        <ul class="mb-0">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<form asp-action="EditAsset" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="AssetId" />
    <input type="hidden" asp-for="CreatedAt" />
    
    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Название *</label>
                <input asp-for="Name" class="form-control" required>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Type" class="form-label">Тип *</label>
                <select asp-for="Type" class="form-select" required>
                    <option value="Server">Server</option>
                    <option value="Workstation">Workstation</option>
                    <option value="Network">Network</option>
                    <option value="Database">Database</option>
                </select>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="IpAddress" class="form-label">IP адрес</label>
                <input asp-for="IpAddress" class="form-control">
            </div>
            
            <div class="mb-3">
                <label asp-for="Os" class="form-label">Операционная система</label>
                <input asp-for="Os" class="form-control">
            </div>
            
            <div class="mb-3">
                <label asp-for="Criticality" class="form-label">Критичность *</label>
                <select asp-for="Criticality" class="form-select" required>
                    <option value="Low">Low</option>
                    <option value="Medium">Medium</option>
                    <option value="High">High</option>
                    <option value="Critical">Critical</option>
                </select>
                <span asp-validation-for="Criticality" class="text-danger"></span>
            </div>
            
            <!-- ← ВЫБОР ТЕНАНТА -->
            <div class="mb-3">
                <label asp-for="TenantId" class="form-label">Тенант *</label>
                <select asp-for="TenantId" class="form-select" required>
                    <option value="">— Выберите тенант —</option>
                    @foreach (var tenant in ViewBag.Tenants)
                    {
                        var selected = tenant.TenantId == Model.TenantId ? "selected" : "";
                        <option value="@tenant.TenantId" @@selected>
                            @tenant.Name (@tenant.Subscription)
                        </option>
                    }
                </select>
                <span asp-validation-for="TenantId" class="text-danger"></span>
                <small class="text-muted">
                    <i class="bi bi-info-circle"></i> При смене тенанта проверяется лимит нового тенанта
                </small>
            </div>
        </div>
    </div>
    
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i> 
        <strong>Внимание:</strong> Смена тенанта может повлиять на лимиты и доступ к активу.
    </div>
    
    <button type="submit" class="btn btn-primary">
        <i class="bi bi-check-circle"></i> Сохранить изменения
    </button>
    <a asp-action="Assets" class="btn btn-secondary">Отмена</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}