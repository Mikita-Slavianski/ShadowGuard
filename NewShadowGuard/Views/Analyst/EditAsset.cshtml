@model NewShadowGuard.Models.Asset
@{
    ViewData["Title"] = "Редактировать актив";
}

<h2>✏️ Редактировать актив</h2>

<form asp-action="EditAsset" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="AssetId" />
    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Название *</label>
                <input asp-for="Name" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label asp-for="Type" class="form-label">Тип *</label>
                    <select asp-for="Type" class="form-select" required>
                        <option value="Server">Server</option>
                        <option value="Workstation">Workstation</option>
                        <option value="Network">Network</option>
                        <option value="Database">Database</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label asp-for="IpAddress" class="form-label">IP адрес</label>
                    <input asp-for="IpAddress" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label asp-for="Os" class="form-label">Операционная система</label>
                        <input asp-for="Os" class="form-control">
                        </div>
                        <div class="mb-3">
                            <label asp-for="Criticality" class="form-label">Критичность *</label>
                            <select asp-for="Criticality" class="form-select" required>
                                <option value="Low">Low</option>
                                <option value="Medium">Medium</option>
                                <option value="High">High</option>
                                <option value="Critical">Critical</option>
                            </select>
                        </div>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary">Сохранить</button>
                <a asp-action="Assets" class="btn btn-secondary">Отмена</a>
            </form>