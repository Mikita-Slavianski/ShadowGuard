@model NewShadowGuard.Models.CorrelationRule
@{
    ViewData["Title"] = "Создать правило корреляции";
}

<h2>➕ Создать правило корреляции</h2>

<form asp-action="CreateCorrelationRule" method="post">
    @Html.AntiForgeryToken()
    
    <div class="row">
        <div class="col-md-8">
            <div class="mb-3">
                <label asp-for="RuleName" class="form-label">Название правила *</label>
                <input asp-for="RuleName" class="form-control" required>
                    <span asp-validation-for="RuleName" class="text-danger"></span>
                </div>
            
                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Описание</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>
            
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="EventType" class="form-label">Тип события *</label>
                        <select asp-for="EventType" class="form-select" required>
                            <option value="">— Выберите —</option>
                            <option value="LoginFailed">LoginFailed</option>
                            <option value="PortScan">PortScan</option>
                            <option value="QueryAnomaly">QueryAnomaly</option>
                            <option value="AuthFailure">AuthFailure</option>
                            <option value="DataAccess">DataAccess</option>
                            <option value="MalwareDetected">MalwareDetected</option>
                            <option value="FileAccess">FileAccess</option>
                        </select>
                        <span asp-validation-for="EventType" class="text-danger"></span>
                    </div>
                
                    <div class="col-md-4 mb-3">
                        <label asp-for="Threshold" class="form-label">Порог срабатывания *</label>
                        <input asp-for="Threshold" type="number" class="form-control" min="1" required>
                            <small class="text-muted">Количество событий для срабатывания</small>
                        </div>
                
                        <div class="col-md-4 mb-3">
                            <label asp-for="TimeWindowMinutes" class="form-label">Временное окно (мин) *</label>
                            <input asp-for="TimeWindowMinutes" type="number" class="form-control" min="1" required>
                                <small class="text-muted">Период для подсчёта событий</small>
                            </div>
                        </div>
            
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Severity" class="form-label">Критичность *</label>
                                <select asp-for="Severity" class="form-select" required>
                                    <option value="Low">Low</option>
                                    <option value="Medium">Medium</option>
                                    <option value="High">High</option>
                                    <option value="Critical">Critical</option>
                                </select>
                            </div>
                
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Статус</label>
                                <div class="form-check form-switch">
                                    <input asp-for="IsActive" class="form-check-input" type="checkbox" checked>
                                        <label class="form-check-label" asp-for="IsActive">Активно</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
    
                    <button type="submit" class="btn btn-success">Создать правило</button>
                    <a asp-action="CorrelationRules" class="btn btn-secondary">Отмена</a>
                </form>