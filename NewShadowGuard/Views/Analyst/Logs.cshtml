@model List<NewShadowGuard.Models.Log>
@{
    ViewData["Title"] = "Логи";
}

<h2>📋 Логи событий</h2>

@if (ViewBag.AssetId != null)
{
    <div class="alert alert-info">
        <i class="bi bi-filter"></i> Фильтр по активу
        <a asp-action="Logs" class="btn btn-sm btn-outline-secondary ms-3">← Все логи</a>
    </div>
}

<!-- Панель экспорта -->
<div class="card mb-4">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h5 class="mb-0">📊 Экспорт логов</h5>
            </div>
            <div class="col-md-6 text-end">
                <div class="btn-group" role="group">
                    <a asp-action="ExportLogs" asp-route-format="excel" asp-route-assetId="@ViewBag.AssetId" class="btn btn-success">
                        📄 Excel
                    </a>
                    <a asp-action="ExportLogs" asp-route-format="csv" asp-route-assetId="@ViewBag.AssetId" class="btn btn-info">
                        📄 CSV
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Время</th>
            <th>Актив</th>
            <th>Тип события</th>
            <th>Данные</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in Model)
        {
            <tr>
                <td>@log.Timestamp.ToString("dd.MM.yyyy HH:mm:ss")</td>
                <td>@log.Asset?.Name</td>
                <td><span class="badge bg-info">@log.EventType</span></td>
                <td>
                    <small>
                        @(log.RawData != null && log.RawData.Length > 100
                            ? log.RawData.Substring(0, 100) + "..."
                            : log.RawData)
                    </small>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="text-muted">
    Показано последних @Model.Count записей из 1000
</div>