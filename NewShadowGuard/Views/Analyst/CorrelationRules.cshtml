@model List<NewShadowGuard.Models.CorrelationRule>
@{
    ViewData["Title"] = "Правила корреляции";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🔗 Правила корреляции</h2>
    <div>
        <a asp-action="CreateCorrelationRule" class="btn btn-success">➕ Создать правило</a>
        <form asp-action="RunCorrelationManual" method="post" style="display:inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-play-circle"></i> Запустить корреляцию
            </button>
        </form>
        <a asp-action="CorrelationHistory" class="btn btn-info">📊 История</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="alert alert-info mb-4">
    <i class="bi bi-info-circle"></i>
    <strong>Как это работает:</strong> Система автоматически анализирует логи и создаёт инциденты
    при обнаружении паттернов, соответствующих правилам корреляции.
</div>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Название</th>
            <th>Тип события</th>
            <th>Порог</th>
            <th>Окно (мин)</th>
            <th>Критичность</th>
            <th>Статус</th>
            <th>Последний запуск</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var rule in Model)
        {
            <tr>
                <td>@rule.RuleId</td>
                <td>
                    <strong>@rule.RuleName</strong>
                    <br>
                    <small class="text-muted">@rule.Description</small>
                </td>
                <td><span class="badge bg-info">@rule.EventType</span></td>
                <td>@rule.Threshold</td>
                <td>@rule.TimeWindowMinutes</td>
                <td>
                    <span class="badge
                        @(rule.Severity == "Critical" ? "bg-danger" :
                                                    rule.Severity == "High" ? "bg-warning" :
                                                    rule.Severity == "Medium" ? "bg-info" : "bg-secondary")">
                        @rule.Severity
                    </span>
                </td>
                <td>
                    <span class="badge @(rule.IsActive ? "bg-success" : "bg-secondary")">
                        @(rule.IsActive ? "Активно" : "Отключено")
                    </span>
                </td>
                <td>
                    @(rule.LastRunAt?.ToString("dd.MM.yyyy HH:mm") ?? "Никогда")
                </td>
                <td>
                    <a asp-action="EditCorrelationRule" asp-route-id="@rule.RuleId"
                       class="btn btn-sm btn-outline-primary">✏️</a>
                    <form asp-action="DeleteCorrelationRule" asp-route-id="@rule.RuleId"
                          method="post" style="display:inline"
                          onsubmit="return confirm('Удалить правило?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">🗑️</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>