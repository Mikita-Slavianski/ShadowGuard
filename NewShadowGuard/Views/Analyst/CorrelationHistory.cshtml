@model List<NewShadowGuard.Models.CorrelationRun>
@{
    ViewData["Title"] = "История корреляции";
}

<h2 class="mb-4">📊 История запусков корреляции</h2>

<a asp-action="CorrelationRules" class="btn btn-secondary mb-4">← Назад к правилам</a>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Время запуска</th>
            <th>Проверено правил</th>
            <th>Создано инцидентов</th>
            <th>Длительность</th>
            <th>Запустил</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var run in Model)
        {
            <tr>
                <td>@run.RunId</td>
                <td>@run.RunAt.ToString("dd.MM.yyyy HH:mm:ss")</td>
                <td>@run.RulesChecked</td>
                <td>
                    <span class="badge @(run.IncidentsCreated > 0 ? "bg-success" : "bg-secondary")">
                        @run.IncidentsCreated
                    </span>
                </td>
                <td>@run.DurationSeconds сек.</td>
                <td>@(run.RunByUser?.FullName ?? "Система")</td>
            </tr>
        }
    </tbody>
</table>