@model List<NewShadowGuard.Models.BlockedIP>
@{
    ViewData["Title"] = "Заблокированные IP";
}

<h2 class="mb-4">🚫 Заблокированные IP-адреса</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>IP-адрес</th>
                    <th>Причина</th>
                    <th>Инцидент</th>
                    <th>Заблокирован</th>
                    <th>Истекает</th>
                    <th>Кем</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ip in Model)
                {
                    var isExpired = ip.ExpiresAt.HasValue && ip.ExpiresAt.Value < DateTime.UtcNow;
                    
                    <tr class="@(ip.IsActive ? "" : "table-secondary")">
                        <td><code>@ip.IpAddress</code></td>
                        <td>@ip.Reason</td>
                        <td>
                            @if (ip.IncidentId.HasValue)
                            {
                                <a asp-action="IncidentDetails" asp-route-id="@ip.IncidentId">
                                    #@ip.IncidentId
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>@ip.BlockedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            @if (ip.ExpiresAt.HasValue)
                            {
                                <span class="@(isExpired ? "text-danger" : "text-muted")">
                                    @ip.ExpiresAt.Value.ToString("dd.MM.yyyy")
                                    @if (isExpired)
                                    {
                                        <span>(Истекло)</span>
                                    }
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Бессрочно</span>
                            }
                        </td>
                        <td>@ip.BlockedByUser?.FullName</td>
                        <td>
                            @if (!ip.IsActive)
                            {
                                <span class="badge bg-secondary">Разблокирован</span>
                            }
                            else if (isExpired)
                            {
                                <span class="badge bg-danger">Истекло</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Активен</span>
                            }
                        </td>
                        <td>
                            @if (ip.IsActive)
                            {
                                <form asp-action="UnblockIP" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="blockedIpId" value="@ip.BlockedIpId" />
                                    <input type="hidden" name="incidentId" value="@ip.IncidentId" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">✅ Разблокировать</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary">← Назад к дашборду</a>