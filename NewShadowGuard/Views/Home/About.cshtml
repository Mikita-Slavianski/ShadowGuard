@{
    ViewData["Title"] = "О проекте";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0">🛡️ CyberSecurity App</h3>
                </div>
                <div class="card-body">
                    <h5>О проекте</h5>
                    <p>
                        Веб-приложение для управления кибербезопасностью компаний.
                        Предназначено для SOC-аналитиков, клиентов и администраторов.
                    </p>
                    
                    <h5 class="mt-4">Функционал</h5>
                    <ul>
                        <li>✅ Управление тенантами и пользователями</li>
                        <li>✅ Мониторинг инцидентов безопасности</li>
                        <li>✅ Управление активами компаний</li>
                        <li>✅ Журнал аудита действий</li>
                        <li>✅ Экспорт данных в Excel/CSV</li>
                        <li>✅ Разграничение прав доступа (3 роли)</li>
                        <li>✅ Управление подписками</li>
                    </ul>
                    
                    <h5 class="mt-4">Технологии</h5>
                    <ul>
                        <li><strong>Backend:</strong> ASP.NET Core MVC, C#, EF Core</li>
                        <li><strong>Database:</strong> SQL Server (LocalDB)</li>
                        <li><strong>Frontend:</strong> Bootstrap 5, Chart.js</li>
                        <li><strong>Security:</strong> BCrypt (хеширование паролей)</li>
                    </ul>
                    
                    <h5 class="mt-4">Роли пользователей</h5>
                    <div class="row mt-3">
                        <div class="col-md-4">
                            <div class="card bg-primary text-white text-center p-3">
                                <h5>👨‍💼 Админ</h5>
                                <small>Полный доступ к системе</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card bg-info text-white text-center p-3">
                                <h5>🔍 Аналитик</h5>
                                <small>Обработка инцидентов</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card bg-success text-white text-center p-3">
                                <h5>📈 Клиент</h5>
                                <small>Просмотр отчётности</small>
                            </div>
                        </div>
                    </div>
                    
                    <hr class="my-4">
                    
                    <p class="text-muted text-center mb-0">
                        Учебный проект | 2025 | ASP.NET Core MVC
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>