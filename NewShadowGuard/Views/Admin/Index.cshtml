@model NewShadowGuard.Controllers.AdminDashboardViewModel
@{
    ViewData["Title"] = "Админ-панель";
}

<h2 class="mb-4">📊 Панель администратора</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Карточки статистики -->
<div class="row mb-4">
    <div class="col-md-2">
        <div class="card text-white bg-primary">
            <div class="card-body text-center">
                <h3>@Model.TenantCount</h3>
                <p class="mb-0">Тенанты</p>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-white bg-success">
            <div class="card-body text-center">
                <h3>@Model.UserCount</h3>
                <p class="mb-0">Пользователи</p>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-white bg-info">
            <div class="card-body text-center">
                <h3>@Model.AssetCount</h3>
                <p class="mb-0">Активы</p>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-white bg-warning">
            <div class="card-body text-center">
                <h3>@Model.IncidentCount</h3>
                <p class="mb-0">Инциденты</p>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-white bg-danger">
            <div class="card-body text-center">
                <h3>@Model.ActiveIncidents</h3>
                <p class="mb-0">Активные</p>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <a asp-action="AuditLog" class="card text-white bg-secondary text-decoration-none">
            <div class="card-body text-center">
                <h3>📝</h3>
                <p class="mb-0">Аудит</p>
            </div>
        </a>
    </div>
</div>

<!-- Графики -->
<div class="row mb-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">📈 Инциденты по статусам</h5>
            </div>
            <div class="card-body">
                <canvas id="incidentsChart" height="100"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">🎯 Распределение по критичности</h5>
            </div>
            <div class="card-body">
                <canvas id="severityChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // График инцидентов по статусам
        const incidentsCtx = document.getElementById('incidentsChart').getContext('2d');
        new Chart(incidentsCtx, {
        type: 'bar',
        data: {
        labels: ['Новые', 'В работе', 'Решены', 'Ложные'],
        datasets: [{
        label: 'Количество',
        data: [@Model.NewIncidents, @Model.InProgressIncidents, @Model.ResolvedIncidents, 0],
        backgroundColor: [
        'rgba(255, 193, 7, 0.8)',
        'rgba(13, 110, 253, 0.8)',
        'rgba(25, 135, 84, 0.8)',
        'rgba(108, 117, 125, 0.8)'
        ],
        borderColor: [
        'rgba(255, 193, 7, 1)',
        'rgba(13, 110, 253, 1)',
        'rgba(25, 135, 84, 1)',
        'rgba(108, 117, 125, 1)'
        ],
        borderWidth: 1
        }]
        },
        options: {
        responsive: true,
        scales: {
        y: { beginAtZero: true, ticks: { stepSize: 1 } }
        }
        }
        });

        // График по критичности (получим данные отдельным запросом или заглушка)
        const severityCtx = document.getElementById('severityChart').getContext('2d');
        new Chart(severityCtx, {
        type: 'doughnut',
        data: {
        labels: ['Critical', 'High', 'Medium', 'Low'],
        datasets: [{
        data: [@Model.CriticalIncidents, 2, 3, 1], // Заглушка - можно улучшить
        backgroundColor: [
        'rgba(220, 53, 69, 0.8)',
        'rgba(255, 193, 7, 0.8)',
        'rgba(13, 110, 253, 0.8)',
        'rgba(108, 117, 125, 0.8)'
        ]
        }]
        },
        options: {
        responsive: true,
        plugins: {
        legend: { position: 'bottom' }
        }
        }
        });
    </script>
}

<!-- Последние тенанты и пользователи -->
<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">🏢 Последние тенанты</h5>
            </div>
            <div class="card-body">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Название</th>
                            <th>План</th>
                            <th>Статус</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tenant in Model.RecentTenants)
                        {
                            <tr>
                                <td>@tenant.Name</td>
                                <td><span class="badge bg-info">@tenant.Subscription</span></td>
                                <td><span class="badge @(tenant.Status == "Active" ? "bg-success" : "bg-danger")">@tenant.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
                <a asp-action="Tenants" class="btn btn-sm btn-outline-primary">Все тенанты →</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">👥 Последние пользователи</h5>
            </div>
            <div class="card-body">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Имя</th>
                            <th>Роль</th>
                            <th>Тенант</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.RecentUsers)
                        {
                            <tr>
                                <td>@user.FullName</td>
                                <td><span class="badge bg-info">@user.Role</span></td>
                                <td>@(user.Tenant?.Name ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <a asp-action="Users" class="btn btn-sm btn-outline-primary">Все пользователи →</a>
            </div>
        </div>
    </div>
</div>

<!-- Быстрые действия -->
<div class="row mt-4">
    <div class="col-md-4">
        <a asp-action="CreateTenant" class="btn btn-primary w-100">➕ Создать тенант</a>
    </div>
    <div class="col-md-4">
        <a asp-action="CreateUser" class="btn btn-success w-100">➕ Создать пользователя</a>
    </div>
    <div class="col-md-4">
        <a asp-action="AuditLog" class="btn btn-secondary w-100">📝 Журнал аудита</a>
    </div>
</div>