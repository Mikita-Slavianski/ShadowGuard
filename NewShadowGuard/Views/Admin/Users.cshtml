@model List<NewShadowGuard.Models.User>
@{
    ViewData["Title"] = "Управление пользователями";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>👥 Пользователи</h2>
    <a asp-action="CreateUser" class="btn btn-success">➕ Создать</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Инфо о лимитах -->
<div class="card mb-4 bg-light">
    <div class="card-body">
        <h6 class="card-title">📊 Лимиты по тенантам</h6>
        <div class="row">
            @foreach (var tenantGroup in Model.GroupBy(u => u.TenantId))
            {
                var tenantId = tenantGroup.Key;
                var tenant = tenantGroup.First().Tenant;
                if (tenant != null)
                {
                    var limits = NewShadowGuard.Services.SubscriptionLimits.GetLimits(tenant.Subscription);
                    var userCount = tenantGroup.Count();
                    var percentage = limits.MaxUsers > 0 ? (userCount * 100 / limits.MaxUsers) : 0;
                    var isUnlimited = NewShadowGuard.Services.SubscriptionLimits.HasUnlimitedUsers(tenant.Subscription);
                    
                    <div class="col-md-4 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <h6 class="card-title">@tenant.Name</h6>
                                <p class="card-text small">
                                    <strong>План:</strong> @tenant.Subscription<br>
                                    <strong>Пользователи:</strong>
                                    @if (isUnlimited)
                                    {
                                        <span class="text-success">♾️ Без ограничений</span>
                                    }
                                    else
                                    {
                                        <span class="@(percentage >= 90 ? "text-danger" : percentage >= 70 ? "text-warning" : "text-success")">
                                            @userCount / @limits.MaxUsers
                                        </span>
                                    }
                                </p>
                                @if (!isUnlimited)
                                {
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar @(percentage >= 90 ? "bg-danger" : percentage >= 70 ? "bg-warning" : "bg-success")"
                                             role="progressbar" style="width: @Math.Min(percentage, 100)%"></div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Email</th>
            <th>Имя</th>
            <th>Роль</th>
            <th>Тенант</th>
            <th>MFA</th>
            <th>Статус</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.UserId</td>
                <td>@user.Email</td>
                <td>@user.FullName</td>
                <td><span class="badge bg-info">@user.Role</span></td>
                <td>@(user.Tenant?.Name ?? "—")</td>
                <td>@(user.MfaEnabled ? "✅" : "❌")</td>
                <td>
                    <span class="badge @(user.IsActive ? "bg-success" : "bg-danger")">
                        @(user.IsActive ? "Active" : "Blocked")
                    </span>
                </td>
                <td>
                    <a asp-action="EditUser" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-primary" title="Редактировать">✏️</a>
                    <form asp-action="ResetPassword" asp-route-id="@user.UserId" method="post" style="display:inline" title="Сбросить пароль">
                        <button type="submit" class="btn btn-sm btn-outline-warning">🔑</button>
                    </form>
                    <form asp-action="DeleteUser" asp-route-id="@user.UserId" method="post" style="display:inline" onsubmit="return confirm('Вы уверены, что хотите удалить пользователя? Это действие нельзя отменить.')" title="Удалить">
                        <button type="submit" class="btn btn-sm btn-outline-danger">🗑️</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>