@model List<NewShadowGuard.Models.Tenant>
@{
    ViewData["Title"] = "Управление тенантами";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🏢 Тенанты</h2>
    <a asp-action="CreateTenant" class="btn btn-primary">➕ Создать</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Название</th>
            <th>Страна</th>
            <th>План</th>
            <th>Статус</th>
            <th>Дата создания</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var tenant in Model)
        {
            <tr>
                <td>@tenant.TenantId</td>
                <td>@tenant.Name</td>
                <td>@tenant.Country</td>
                <td><span class="badge bg-info">@tenant.Subscription</span></td>
                <td>
                    <span class="badge @(tenant.Status == "Active" ? "bg-success" : "bg-danger")">
                        @tenant.Status
                    </span>
                </td>
                <td>@tenant.CreatedAt.ToString("dd.MM.yyyy")</td>
                <td>
                    <a asp-action="EditTenant" asp-route-id="@tenant.TenantId" class="btn btn-sm btn-outline-primary">✏️</a>
                    <form asp-action="DeleteTenant" asp-route-id="@tenant.TenantId" method="post" style="display:inline" onsubmit="return confirm('Удалить тенант?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger">🗑️</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>