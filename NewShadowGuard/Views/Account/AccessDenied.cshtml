@{
    ViewData["Title"] = "Доступ запрещён";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-danger text-white text-center">
                    <h4 class="mb-0">⛔ Ошибка</h4>
                </div>
                <div class="card-body text-center">
                    <h1 class="display-1 text-danger">🔒</h1>
                    <h5>У вас нет прав для доступа к этой странице</h5>
                    <p class="text-muted">Обратитесь к администратору системы</p>
                    <a asp-action="Login" class="btn btn-primary">Вернуться на страницу входа</a>
                </div>
            </div>
        </div>
    </div>
</div>