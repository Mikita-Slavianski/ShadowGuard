@model NewShadowGuard.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
}

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white text-center">
                    <h4 class="mb-0">🔐 Регистрация в CyberSecurity App</h4>
                </div>
                <div class="card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <h5>Ошибки:</h5>
                            <ul class="mb-0">
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            </ul>
                        </div>
                    }

                    <form asp-action="Register" method="post">
                        @Html.AntiForgeryToken()
                        
                        <h5 class="text-primary mb-3">📋 Основная информация</h5>
                        
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">📧 Email *</label>
                            <input asp-for="Email" type="email" class="form-control"
                                   placeholder="your@email.com" required autofocus>
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="FullName" class="form-label">👤 Полное имя *</label>
                                <input asp-for="FullName" type="text" class="form-control"
                                       placeholder="Иванов Иван" required>
                                    <span asp-validation-for="FullName" class="text-danger"></span>
                                </div>

                                <hr class="my-4">

                                <h5 class="text-primary mb-3">🔑 Безопасность</h5>

                                <div class="mb-3">
                                    <label asp-for="Password" class="form-label">🔒 Пароль *</label>
                                    <input asp-for="Password" type="password" class="form-control"
                                           placeholder="Минимум 6 символов" required>
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                        <div class="form-text">
                                            Пароль должен содержать минимум 6 символов
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="ConfirmPassword" class="form-label">🔒 Подтверждение пароля *</label>
                                        <input asp-for="ConfirmPassword" type="password" class="form-control"
                                               placeholder="Повторите пароль" required>
                                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                        </div>

                                        <hr class="my-4">

                                        <h5 class="text-primary mb-3">🏢 Информация о компании (опционально)</h5>
                                        <p class="text-muted small">
                                            <i class="bi bi-info-circle"></i>
                                            Если вы представитель компании, укажите её данные.
                                            Будет создан новый тенант с пробным периодом 1 месяц.
                                        </p>

                                        <div class="mb-3">
                                            <label asp-for="CompanyName" class="form-label">🏢 Название компании</label>
                                            <input asp-for="CompanyName" type="text" class="form-control"
                                                   placeholder="ООО Пример">
                                                <span asp-validation-for="CompanyName" class="text-danger"></span>
                                            </div>

                                            <div class="mb-3">
                                                <label asp-for="Country" class="form-label">🌍 Страна</label>
                                                <input asp-for="Country" type="text" class="form-control"
                                                       placeholder="Россия" value="Россия">
                                                    <span asp-validation-for="Country" class="text-danger"></span>
                                                </div>

                                                <hr class="my-4">

                                                <div class="d-grid gap-2">
                                                    <button type="submit" class="btn btn-success btn-lg">
                                                        <i class="bi bi-check-circle"></i> Зарегистрироваться
                                                    </button>
                                                </div>
                                            </form>

                                            <hr class="my-4">

                                            <div class="text-center">
                                                <p class="mb-0">
                                                    Уже есть аккаунт?
                                                    <a asp-action="Login" class="text-decoration-none">🔐 Войти</a>
                                                </p>
                                            </div>

                                            <div class="alert alert-info mt-4">
                                                <h6>📋 Что вы получите после регистрации:</h6>
                                                <ul class="mb-0 small">
                                                    <li>✅ Роль <strong>Клиент</strong> с доступом к дашборду</li>
                                                    <li>✅ Просмотр инцидентов безопасности (только чтение)</li>
                                                    <li>✅ Просмотр активов вашей компании</li>
                                                    <li>✅ Генерация отчётов по инцидентам</li>
                                                    @*<li>✅ Пробный период 1 месяц (при указании компании)</li>*@
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @section Scripts {
                            @{
                                await Html.RenderPartialAsync("_ValidationScriptsPartial");
                            }
                        }